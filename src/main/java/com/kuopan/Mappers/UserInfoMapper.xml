<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.kuopan.DAO.UserInfoMapper">

    <update id="updateRemainSpaceByGUID">
        update user_info
        set occu_space = occu_space + #{occu_space}
        where user_id = #{id};
    </update>

</mapper>
